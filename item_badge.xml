<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/AppCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Emoji -->
        <TextView
            android:id="@+id/tvBadgeEmoji"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="🏅"
            android:textSize="24sp"
            android:gravity="center"/>

        <!-- Title + description + progress -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/tvBadgeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Badge Title"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/tvBadgeDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Badge description"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

            <ProgressBar
                android:id="@+id/progressBadge"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="6dp"
                android:max="10"
                android:progress="0"
                android:progressTint="#6C5CE7"
                android:progressBackgroundTint="#2D2550"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Status icon: ✅ earned / 🔒 locked / ⚠️ warning -->
        <TextView
            android:id="@+id/tvBadgeStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒"
            android:textSize="20sp"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>