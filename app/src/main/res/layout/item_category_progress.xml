<?xml version="1.0" encoding="utf-8"?>
<!-- Single category row in the Dashboard Category Breakdown section -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_category_row"
    android:padding="12dp">

    <!-- Row 1: name + optional "Over Budget" badge + amount/limit -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp">

        <!-- Category name -->
        <TextView
            android:id="@+id/tvCategoryName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- "Over Budget" badge (hidden by default) -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipOverBudget"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="@string/over_budget_badge"
            android:textColor="@color/white"
            android:textSize="10sp"
            app:chipBackgroundColor="@color/status_red"
            app:chipCornerRadius="4dp"
            app:chipMinHeight="24dp"
            app:chipStrokeWidth="0dp"
            android:visibility="gone"
            app:layout_constraintStart_toEndOf="@id/tvCategoryName"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="8dp"/>

        <!-- Amount: spent / limit -->
        <TextView
            android:id="@+id/tvCategoryAmounts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/progressCategory"
        style="@style/BudgetProgressBar"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:max="100"
        android:progress="0"
        android:layout_marginBottom="4dp"/>

    <!-- Row 3: pct used + (optional) over by amount -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvCategoryPct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/tvCategoryOverAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/status_red"
            android:textSize="11sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>