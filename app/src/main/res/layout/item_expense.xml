<?xml version="1.0" encoding="utf-8"?>
<!-- Single expense row in the RecyclerView -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:paddingVertical="12dp">

    <!-- Left: description + date + category chip -->
    <LinearLayout
        android:id="@+id/llExpenseInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/llExpenseRight">

        <!-- Description -->
        <TextView
            android:id="@+id/tvExpenseDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="4dp"/>

        <!-- Date + Category chip row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_calendar"
                android:tint="@color/text_secondary"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/tvExpenseDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCategory"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:textSize="10sp"
                android:textColor="@color/white"
                app:chipCornerRadius="4dp"
                app:chipMinHeight="24dp"
                app:chipStrokeWidth="0dp"
                app:ensureMinTouchTargetSize="false"/>

        </LinearLayout>
    </LinearLayout>

    <!-- Right: camera icon (if photo) + amount -->
    <LinearLayout
        android:id="@+id/llExpenseRight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Camera icon (only visible if expense has a photo) -->
        <ImageView
            android:id="@+id/ivPhotoIndicator"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_camera"
            android:tint="@color/accent_purple"
            android:layout_marginEnd="6dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tvExpenseAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"/>

    </LinearLayout>

    <!-- Bottom divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/llExpenseInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>