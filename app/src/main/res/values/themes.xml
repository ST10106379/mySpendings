<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.BudgetTracker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorPrimaryVariant">@color/accent_purple_dark</item>
        <item name="colorSecondary">@color/status_green</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_secondary</item>
        <item name="colorError">@color/status_red</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_secondary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <!-- Global text appearance -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- ============ BUTTON STYLES ============ -->

    <!-- Purple gradient button (Log In, Save, Create, etc.) -->
    <style name="PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent_purple</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Outline/ghost button -->
    <style name="SecondaryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/border_input</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">15sp</item>
    </style>

    <!-- Small icon button (edit/delete on cards) -->
    <style name="IconButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:padding">6dp</item>
        <item name="rippleColor">@color/accent_purple_dim</item>
    </style>

    <!-- ============ INPUT STYLES ============ -->

    <style name="InputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/bg_input</item>
        <item name="boxStrokeColor">@color/border_input</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="hintTextColor">@color/text_muted</item>
        <item name="android:textColorHint">@color/text_muted</item>
    </style>

    <style name="InputEditText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- ============ CARD STYLES ============ -->

    <style name="AppCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="strokeColor">@color/border_default</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="AppCard.Accent">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="strokeColor">@color/accent_purple</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- ============ TEXT STYLES ============ -->

    <style name="TextHeading" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">24sp</item>
    </style>

    <style name="TextSubheading" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="TextLabel" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="TextAmount" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">28sp</item>
    </style>

    <!-- ============ CHIP STYLE (category tags) ============ -->

    <style name="CategoryChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipMinHeight">24dp</item>
        <item name="chipCornerRadius">4dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="chipStrokeWidth">0dp</item>
    </style>

    <!-- ============ PROGRESS BAR ============ -->

    <style name="BudgetProgressBar" parent="Widget.AppCompat.ProgressBar.Horizontal">
        <item name="android:progressBackgroundTint">@color/progress_bg</item>
        <item name="android:progressTint">@color/progress_ok</item>
        <item name="android:maxHeight">6dp</item>
        <item name="android:minHeight">6dp</item>
    </style>

    <!-- ============ DIALOG STYLE ============ -->

    <style name="DarkDialog" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="android:colorBackground">@color/bg_card</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="colorPrimary">@color/accent_purple</item>
    </style>

</resources>
